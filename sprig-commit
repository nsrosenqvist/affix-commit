#!/usr/bin/env bash
# sprig-commit — inject ticket IDs from branch names into conventional commit scopes
# https://github.com/nsrosenqvist/sprig-commit
set -euo pipefail

# --- Defaults ---
ticket_pattern='[A-Z]+-[0-9]+'
ignored_branches='^(master|main|dev|develop|development|release)$'
ignore_missing_tickets=false
default_type=chore
infer_type_from_branch=false
branch_type_map='feat:feat,fix:fix,chore:chore,refactor:refactor,docs:docs,test:test,style:style,perf:perf,build:build,ci:ci,revert:revert,feature:feat,bugfix:fix,hotfix:fix'

# --- Config loading ---
load_config() {
  local config_file=""
  local repo_root

  repo_root="$(git rev-parse --show-toplevel 2>/dev/null)" || return 0

  if [[ -f "${repo_root}/.sprig-commit.cfg" ]]; then
    config_file="${repo_root}/.sprig-commit.cfg"
  elif [[ -f "${HOME}/.sprig-commit.cfg" ]]; then
    config_file="${HOME}/.sprig-commit.cfg"
  fi

  if [[ -n "${config_file}" ]]; then
    # Security: only source lines that match safe key=value patterns.
    # Allow regex metacharacters (^$|()[]+ etc.) but block command substitution
    # ($(...), `...`) and semicolons.
    local safe_lines
    safe_lines=$(grep -E '^\s*(ticket_pattern|ignored_branches|ignore_missing_tickets|default_type|infer_type_from_branch|branch_type_map)\s*=' "$config_file" \
      | grep -vE '`|\$\(' \
      | grep -E "^[a-z_]+=['\"]?[^;\`]*['\"]?\s*$" || true)

    if [[ -n "${safe_lines}" ]]; then
      eval "${safe_lines}"
    fi
  fi
}

# --- Main ---
main() {
  local commit_msg_file="${1:-}"

  if [[ -z "${commit_msg_file}" ]]; then
    echo "sprig-commit: error: commit message file path required (passed by git)" >&2
    exit 1
  fi

  if [[ ! -f "${commit_msg_file}" ]]; then
    echo "sprig-commit: error: commit message file not found: ${commit_msg_file}" >&2
    exit 1
  fi

  load_config

  # Get current branch name; exit silently on detached HEAD
  local branch
  branch="$(git symbolic-ref --short HEAD 2>/dev/null)" || exit 0

  # Check if branch is ignored
  if [[ "${branch}" =~ ${ignored_branches} ]]; then
    exit 0
  fi

  # Extract ticket from branch name
  local ticket=""
  if [[ "${branch}" =~ ${ticket_pattern} ]]; then
    ticket="${BASH_REMATCH[0]}"
  fi

  # Determine the type to use when wrapping non-conventional messages.
  # When infer_type_from_branch=true, look up the branch prefix (segment before
  # the first '/') in branch_type_map. `inferred` is true only when the prefix
  # actually matched an entry in the map (not when we fell back to default_type).
  local wrap_type="${default_type}"
  local inferred=false
  if [[ "${infer_type_from_branch}" == "true" && "${branch}" == */* ]]; then
    local prefix="${branch%%/*}"
    local pair key val IFS_old="${IFS}"
    IFS=','
    for pair in ${branch_type_map}; do
      key="${pair%%:*}"
      val="${pair#*:}"
      if [[ "${prefix}" == "${key}" && -n "${val}" ]]; then
        wrap_type="${val}"
        inferred=true
        break
      fi
    done
    IFS="${IFS_old}"
  fi

  if [[ -z "${ticket}" ]]; then
    if [[ "${ignore_missing_tickets}" != "true" ]]; then
      echo "sprig-commit: error: no ticket ID found in branch '${branch}'" >&2
      echo "sprig-commit: set ignore_missing_tickets=true in .sprig-commit.cfg to suppress" >&2
      exit 1
    fi
    # No ticket, but ignore_missing_tickets=true. Only continue if we
    # successfully inferred a type from the branch prefix; otherwise there
    # is nothing meaningful to inject and we exit silently.
    if [[ "${inferred}" != "true" ]]; then
      exit 0
    fi
  fi

  # Read the commit message
  local message
  message="$(<"${commit_msg_file}")"

  # Find the first non-comment line
  local first_line=""
  local first_line_num=-1
  local line_num=0

  while IFS= read -r line; do
    # Stop at scissors separator (verbose commit / git status)
    if [[ "${line}" == *"------------------------ >8 ------------------------"* ]]; then
      break
    fi

    if [[ ! "${line}" =~ ^[[:space:]]*# ]] && [[ -n "${line}" || ${first_line_num} -eq -1 ]]; then
      if [[ ${first_line_num} -eq -1 ]] && [[ -n "${line// /}" ]]; then
        first_line="${line}"
        first_line_num=${line_num}
      fi
    fi
    line_num=$((line_num + 1))
  done <<< "${message}"

  # Build the optional scope suffix from the ticket. Empty when there is no
  # ticket (only possible when type inference is active without a ticket).
  local scope_suffix=""
  if [[ -n "${ticket}" ]]; then
    scope_suffix="(${ticket})"
  fi

  # If no content line found (empty / only comments), generate a conventional commit
  if [[ ${first_line_num} -eq -1 ]]; then
    local generated="${wrap_type}${scope_suffix}: wip"
    # Prepend the generated line before any existing content
    if [[ -n "${message}" ]]; then
      printf '%s\n%s\n' "${generated}" "${message}" > "${commit_msg_file}"
    else
      printf '%s\n' "${generated}" > "${commit_msg_file}"
    fi
    exit 0
  fi

  # If the ticket is already in the message, skip
  if [[ -n "${ticket}" ]] && grep -qF "${ticket}" <<< "${message}"; then
    exit 0
  fi

  # Try to parse as a conventional commit:
  #   type(scope)!: message   or   type!: message   or   type: message
  local cc_pattern='^([a-z]+)(\(([^)]+)\))?(!)?: (.+)$'
  local type scope bang msg new_line

  if [[ "${first_line}" =~ ${cc_pattern} ]]; then
    # Already conventional. Without a ticket there is nothing to inject —
    # the user's explicit type wins over branch inference, so leave it alone.
    if [[ -z "${ticket}" ]]; then
      exit 0
    fi

    type="${BASH_REMATCH[1]}"
    scope="${BASH_REMATCH[3]:-}"
    bang="${BASH_REMATCH[4]:-}"
    msg="${BASH_REMATCH[5]}"

    if [[ -n "${scope}" ]]; then
      new_line="${type}(${scope}, ${ticket})${bang}: ${msg}"
    else
      new_line="${type}(${ticket})${bang}: ${msg}"
    fi
  else
    # Not a conventional commit — wrap it in one
    new_line="${wrap_type}${scope_suffix}: ${first_line}"
  fi

  # Replace the first content line in the file, preserving all other lines
  local output=""
  local replaced=false
  line_num=0

  while IFS= read -r line; do
    if [[ ${line_num} -eq ${first_line_num} ]] && [[ "${replaced}" == "false" ]]; then
      output+="${new_line}"$'\n'
      replaced=true
    else
      output+="${line}"$'\n'
    fi
    line_num=$((line_num + 1))
  done <<< "${message}"

  # Write back (remove trailing newline added by the loop, preserve original ending)
  printf '%s' "${output%$'\n'}" > "${commit_msg_file}"

  # Preserve final newline if original had one
  if [[ "${message}" == *$'\n' ]]; then
    printf '\n' >> "${commit_msg_file}"
  fi
}

main "$@"
